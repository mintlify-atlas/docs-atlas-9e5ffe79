  "keyFeatures": [
    "Firebase Authentication with bearer token verification",
    "Role-based access control (CUSTOMER, BAKER, ADMIN)",
    "Multi-bakery marketplace with nearby search (Haversine distance)",
    "Full order lifecycle management with QR code pickup verification",
    "Loyalty stamp card system (9 stamps → free item reward)",
    "Simulated payment processing (credit card, debit, PSE, cash on pickup)",
    "Firebase Cloud Messaging push notifications for order status changes",
    "Firebase Storage image uploads for products and bakery branding",
    "Promotions engine (percentage, fixed amount, happy hour discounts)",
    "Real-time statistics dashboards for bakers and admins"
  ],
  "publicApiSurface": [
    "GET /health",
    "GET /api/v1/bakeries",
    "GET /api/v1/bakeries/nearby",
    "GET /api/v1/bakeries/{id}",
